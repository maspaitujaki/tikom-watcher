# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- Telegram ---
# Get a token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
# Optional: your personal chat id, for "site may have changed / blocked" warnings.
# DM @userinfobot to find it, or leave blank to disable admin warnings.
ADMIN_CHAT_ID=

# --- Postgres ---
# Used by the postgres container AND to build the app's DATABASE_URL in compose.
POSTGRES_USER=tikom
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tikom

# Only used when running the app OUTSIDE docker (go run ./cmd/watcher).
# In docker-compose this is overridden to use the 'postgres' service host.
DATABASE_URL=postgres://tikom:change-me@localhost:5432/tikom?sslmode=disable

# --- Misc ---
LOG_LEVEL=info
